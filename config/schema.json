{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/steamos-time-guardian/config.schema.json",
  "title": "SteamOS Time Guardian configuration",
  "type": "object",
  "required": ["schema_version", "daily_limits", "warnings", "timer", "restriction", "detector", "history", "logging", "simulation"],
  "properties": {
    "schema_version": { "const": 2 },
    "language": { "enum": ["en", "es"] },
    "daily_limits": {
      "type": "object",
      "required": ["enabled", "reset_at", "timezone", "weekly", "allowed_periods"],
      "properties": {
        "enabled": { "type": "boolean" },
        "reset_at": { "type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$" },
        "timezone": { "type": "string", "minLength": 1 },
        "weekly": {
          "type": "object",
          "required": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
          "additionalProperties": false,
          "properties": {
            "monday": { "$ref": "#/$defs/dayLimit" },
            "tuesday": { "$ref": "#/$defs/dayLimit" },
            "wednesday": { "$ref": "#/$defs/dayLimit" },
            "thursday": { "$ref": "#/$defs/dayLimit" },
            "friday": { "$ref": "#/$defs/dayLimit" },
            "saturday": { "$ref": "#/$defs/dayLimit" },
            "sunday": { "$ref": "#/$defs/dayLimit" }
          }
        },
        "allowed_periods": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$" },
              "end": { "type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$" },
              "days": { "type": "array", "items": { "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"] }, "uniqueItems": true }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "object",
      "required": ["threshold_minutes", "notify_at_exhaustion", "native_desktop_notifications"],
      "properties": {
        "threshold_minutes": { "type": "array", "items": { "type": "integer", "minimum": 1, "maximum": 1440 }, "uniqueItems": true },
        "notify_at_exhaustion": { "type": "boolean" },
        "native_desktop_notifications": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "timer": {
      "type": "object",
      "required": ["count_only_while_playing", "default_minutes", "default_action"],
      "properties": {
        "count_only_while_playing": { "type": "boolean" },
        "default_minutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "default_action": { "enum": ["inherit", "notify_only", "soft", "close", "block"] }
      },
      "additionalProperties": false
    },
    "restriction": {
      "type": "object",
      "required": ["level", "grace_seconds", "close_timeout_seconds", "force_kill_enabled", "launch_grace_seconds", "safe_process_fallback"],
      "properties": {
        "level": { "type": "integer", "minimum": 0, "maximum": 3 },
        "grace_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
        "close_timeout_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
        "force_kill_enabled": { "type": "boolean" },
        "launch_grace_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
        "safe_process_fallback": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "detector": {
      "type": "object",
      "required": ["mode", "steam_log_path", "procfs_fallback_interval_seconds", "decky_signal_ttl_seconds", "ignored_app_ids", "ignored_names"],
      "properties": {
        "mode": { "enum": ["auto", "steam_log", "procfs", "disabled"] },
        "steam_log_path": { "type": "string" },
        "procfs_fallback_interval_seconds": { "type": "integer", "minimum": 5, "maximum": 300 },
        "decky_signal_ttl_seconds": { "type": "integer", "minimum": 5, "maximum": 300 },
        "ignored_app_ids": { "type": "array", "items": { "type": "string", "pattern": "^[0-9]+$" }, "uniqueItems": true },
        "ignored_names": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "history": {
      "type": "object",
      "required": ["retention_days", "checkpoint_seconds", "backup_count"],
      "properties": {
        "retention_days": { "type": "integer", "minimum": 1, "maximum": 3650 },
        "checkpoint_seconds": { "type": "integer", "minimum": 5, "maximum": 600 },
        "backup_count": { "type": "integer", "minimum": 0, "maximum": 20 }
      },
      "additionalProperties": false
    },
    "logging": {
      "type": "object",
      "required": ["level", "max_bytes", "backup_count"],
      "properties": {
        "level": { "enum": ["DEBUG", "INFO", "WARNING", "ERROR"] },
        "max_bytes": { "type": "integer", "minimum": 100000, "maximum": 100000000 },
        "backup_count": { "type": "integer", "minimum": 0, "maximum": 20 }
      },
      "additionalProperties": false
    },
    "simulation": {
      "type": "object",
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "dayLimit": {
      "type": "object",
      "required": ["minutes", "unlimited"],
      "properties": {
        "minutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
        "unlimited": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
